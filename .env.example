# Admin (JWT session cookie; use a long random secret in production)
ADMIN_PASSWORD=change_this_to_a_strong_password
ADMIN_JWT_SECRET=replace_with_a_long_random_secret

# --- CMS storage (use ONE option) ---

# Option A — TCP Redis URL (e.g. Redis Cloud: redis:// or rediss://)
# If REDIS_URL is set, it is used and Vercel KV REST vars are ignored.
REDIS_URL=

# Option B — Vercel KV REST (Upstash) — only if you do NOT set REDIS_URL
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# (Same URL is sometimes labeled KV_URL in docs.)

# Vercel Blob — Read/Write token from a **Public** store (required for CMS images on the site).
# Private stores cannot use access:public in the API; access level is fixed at store creation — create a new Public Blob store if you see that error.
BLOB_READ_WRITE_TOKEN=

# Resend API key for form email delivery
# Get your key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx

# Optional: Custom "from" email (must be verified in Resend)
# RESEND_FROM_EMAIL=STEPS LAB <noreply@yourdomain.com>
