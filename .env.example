ADMIN_PASSWORD=change_this_to_a_strong_password
ADMIN_JWT_SECRET=replace_with_a_long_random_secret

# Redis (Redis Cloud, etc.) — paste the full URL from your provider
# Non-TLS: redis://default:PASSWORD@redis-xxxxx.cloud.redislabs.com:PORT
# TLS (often required): rediss://default:PASSWORD@redis-xxxxx.cloud.redislabs.com:PORT
REDIS_URL=
# Resend API key for form email delivery
# Get your key at https://resend.com
# Replace re_xxxxxxxxxxxx with your real API key
RESEND_API_KEY=re_xxxxxxxxxxxx

# Optional: Custom "from" email (must be verified in Resend)
# Default: STEPS LAB <onboarding@resend.dev>
# RESEND_FROM_EMAIL=STEPS LAB <noreply@yourdomain.com>
